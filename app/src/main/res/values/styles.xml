<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base App Style to satisfy AAPT implicit inheritance -->
    <style name="Widget.App" parent="" />

    <!-- Header Styles -->
    <style name="Widget.App.Header">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/brand_primary</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingHorizontal">@dimen/spacing_medium</item>
        <item name="android:paddingVertical">@dimen/spacing_tiny</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.App.Header.Vertical">
        <item name="android:orientation">vertical</item>
        <item name="android:paddingHorizontal">@dimen/header_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/header_padding_top</item>
        <item name="android:paddingBottom">@dimen/header_padding_bottom</item>
    </style>

    <style name="Widget.App.HeaderText" parent="android:Widget.TextView">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_size_h3</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.HeaderText.Large">
        <item name="android:textSize">@dimen/text_size_h2</item>
    </style>

    <style name="Widget.App.HeaderSubtitle" parent="android:Widget.TextView">
        <item name="android:textColor">@color/text_light</item>
        <item name="android:textSize">@dimen/text_size_tiny</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.App.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/elevation_low</item>
        <item name="cardBackgroundColor">@color/card_surface</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:layout_marginBottom">@dimen/spacing_medium</item>
        <item name="android:layout_marginHorizontal">@dimen/spacing_medium</item>
    </style>

    <style name="Widget.App.Card.Inner">
        <item name="cardCornerRadius">@dimen/card_corner_radius_soft</item>
        <item name="android:layout_marginBottom">@dimen/spacing_small</item>
        <item name="android:layout_marginHorizontal">@dimen/spacing_small</item>
    </style>

    <!-- Form Element Styles -->
    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="android:layout_marginBottom">@dimen/spacing_medium</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
    </style>

    <style name="Widget.App.Button.Primary">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Status Badge Styles -->
    <style name="Widget.App.Badge">
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:textSize">@dimen/text_size_tiny</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Widget.App.ResultCount">
        <item name="android:textColor">@color/brand_primary_light</item>
        <item name="android:textSize">@dimen/text_size_small</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingVertical">@dimen/spacing_small</item>
    </style>
</resources>