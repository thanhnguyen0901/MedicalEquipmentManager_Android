<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/app_bg">

    <!-- Top Header Profile Area -->
    <LinearLayout
        style="@style/Widget.App.Header.Vertical">

        <TextView
            style="@style/Widget.App.HeaderText.Large"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title" />

        <TextView
            style="@style/Widget.App.HeaderSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:text="@string/home_subtitle"
            android:textSize="@dimen/text_size_body" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Category Menu Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategories"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/icon_box_size"
                        android:layout_height="@dimen/icon_box_size"
                        app:cardBackgroundColor="@color/icon_bg_teal"
                        app:cardCornerRadius="@dimen/card_corner_radius_soft"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/brand_primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/screen_padding"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/menu_categories"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_title"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_categories"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/text_light" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Equipment Menu Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEquipment"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/icon_box_size"
                        android:layout_height="@dimen/icon_box_size"
                        app:cardBackgroundColor="@color/icon_bg_blue"
                        app:cardCornerRadius="@dimen/card_corner_radius_soft"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_menu_manage"
                            app:tint="@color/info" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/screen_padding"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/menu_equipment"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_title"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_equipment"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/text_light" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reports Menu Item -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardReports"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/icon_box_size"
                        android:layout_height="@dimen/icon_box_size"
                        app:cardBackgroundColor="@color/icon_bg_green"
                        app:cardCornerRadius="@dimen/card_corner_radius_soft"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_menu_report_image"
                            app:tint="@color/report_green" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/screen_padding"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/menu_reports"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_title"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/desc_reports"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/text_light" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>