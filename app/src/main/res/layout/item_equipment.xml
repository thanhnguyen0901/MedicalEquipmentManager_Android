<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/list_horizontal_padding"
    android:paddingVertical="@dimen/list_item_vertical_spacing">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.App.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        app:cardCornerRadius="@dimen/card_corner_radius_soft"
        app:cardElevation="@dimen/elevation_low"
        app:rippleColor="@color/ripple_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/item_inner_padding">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvEquipName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_small"
                    android:layout_toStartOf="@+id/containerActions"
                    android:ellipsize="end"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="2"
                    android:text="@string/hint_equip_name"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/containerActions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivEditEquipment"
                        android:layout_width="@dimen/equipment_action_icon_size"
                        android:layout_height="@dimen/equipment_action_icon_size"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/desc_edit_equipment"
                        android:padding="@dimen/equipment_action_icon_padding"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/action_edit" />

                    <ImageView
                        android:id="@+id/ivDeleteEquipment"
                        android:layout_width="@dimen/equipment_action_icon_size"
                        android:layout_height="@dimen/equipment_action_icon_size"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/desc_delete_equipment"
                        android:padding="@dimen/equipment_action_icon_padding"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="@color/action_delete" />
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEquipStatus"
                    style="@style/Widget.App.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge"
                    android:paddingHorizontal="@dimen/badge_padding_horizontal_compact"
                    android:paddingVertical="@dimen/badge_padding_vertical_compact"
                    android:text="@string/status_active"
                    android:textSize="@dimen/badge_text_size_compact"
                    android:textStyle="bold" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:layout_marginHorizontal="10dp"
                    android:background="@color/divider" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:importantForAccessibility="no"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="@color/text_muted" />

                <TextView
                    android:id="@+id/tvEquipBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/hint_equip_brand"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_tiny" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/separator_dot"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_tiny" />

                <TextView
                    android:id="@+id/tvEquipYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_year"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_tiny" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
