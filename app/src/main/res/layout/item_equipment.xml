<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.App.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_small"
    android:layout_marginVertical="@dimen/spacing_tiny"
    app:rippleColor="@color/ripple_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvEquipName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/containerStatusActions"
                android:layout_marginEnd="@dimen/spacing_small"
                android:text="@string/hint_equip_name"
                android:textColor="@color/brand_primary"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <LinearLayout
                android:id="@+id/containerStatusActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvEquipStatus"
                    style="@style/Widget.App.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/status_active_bg"
                    android:text="@string/status_active"
                    android:textColor="@color/status_active" />

                <ImageView
                    android:id="@+id/ivEditEquipment"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="@dimen/spacing_medium"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/brand_secondary"
                    android:alpha="0.7" />

                <ImageView
                    android:id="@+id/ivDeleteEquipment"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="@dimen/spacing_medium"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="@color/error"
                    android:alpha="0.7" />
            </LinearLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_small"
            android:background="@color/divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/text_muted" />

            <TextView
                android:id="@+id/tvEquipBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/hint_equip_brand"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_small" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginHorizontal="@dimen/spacing_small"
                android:background="@color/text_hint" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="@color/text_muted" />

            <TextView
                android:id="@+id/tvEquipYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/placeholder_year"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_small" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
