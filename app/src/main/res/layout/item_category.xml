<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/list_horizontal_padding"
    android:paddingVertical="@dimen/list_item_vertical_spacing">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.App.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="0dp"
        app:cardCornerRadius="@dimen/card_corner_radius_soft"
        app:cardElevation="@dimen/elevation_low"
        app:rippleColor="@color/ripple_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/item_inner_padding">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/category_icon_size"
                android:layout_height="@dimen/category_icon_size"
                app:cardBackgroundColor="@color/bg_decorative"
                app:cardCornerRadius="@dimen/input_corner_radius"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/symbol_hash"
                    android:textColor="@color/brand_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCategoryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_category_name"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategoryId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/hint_category_id"
                    android:textColor="@color/text_muted"
                    android:textSize="@dimen/text_size_tiny"
                    android:letterSpacing="0.02" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivEditCategory"
                    android:layout_width="@dimen/category_action_icon_size"
                    android:layout_height="@dimen/category_action_icon_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/desc_edit_category"
                    android:padding="@dimen/category_action_icon_padding"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/action_edit" />

                <ImageView
                    android:id="@+id/ivDeleteCategory"
                    android:layout_width="@dimen/category_action_icon_size"
                    android:layout_height="@dimen/category_action_icon_size"
                    android:layout_marginStart="@dimen/spacing_tiny"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/desc_delete_category"
                    android:padding="@dimen/category_action_icon_padding"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="@color/action_delete" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
